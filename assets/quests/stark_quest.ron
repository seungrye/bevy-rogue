// ═══════════════════════════════════════════════════════════════════════════
//  전쟁의 서막 — 롭 스타크 루트
//
//  NPC: 캣린
//  선행 조건: prologue_fog에서 character = "stark" 각성
//
//  ─── 서사 흐름 ──────────────────────────────────────────────��─────────────
//    발단: 아버지 에다드의 처형 소식을 캣린에게 전해 듣는다
//    전개: 북부 영주들의 충성 서약을 받고 전쟁 준비를 한다
//    절정: 속삭이는 숲 매복전 — 제이미 라니스터와 1:1 결투
//    결말: 제이미 생포, "북부의 왕!" 대관식
//
//  ─── 루트 조건 ────────────────────────────────────────────────────────────
//    dormant → (FlagIs character=stark) → war_briefing
// ═══════════════════════════════════════════════════════════════════════════

QuestDef(
    id: "stark_quest",
    title: "전쟁의 서막",
    giver_npc: "캣린",
    initial_phase: "dormant",
    spawn_chance: 0.6,

    phases: {

        // ── 잠든 상태: 각성 전 ────────────────────────────────────────────
        "dormant": QuestPhaseDef(
            dialog: [
                "...북쪽에서 온 분이시군요. 하지만 아직은 이야기를 나눌 때가 아닌 것 같아요.",
                "당신이 진정 누구인지 먼저 알아야 할 것 같습니다.",
            ],
            on_interact: [],
            auto_advance: [
                AutoAdvance(
                    condition: FlagIs(flag: "character", value: "stark"),
                    next_phase: "war_briefing",
                ),
            ],
            objective: None,
        ),

        // ── 발단: 아버지의 죽음 ───────────────────────────────────────────
        "war_briefing": QuestPhaseDef(
            dialog: [
                "롭... 아버지가 돌아가셨어요. 킹스랜딩에서. 반역죄로 처형당하셨습니다.",
                "제프리 왕의 명이었지만, 그 뒤에 라니스터 가문의 손이 있었어요.",
                "북부 영주들이 모이고 있어요. 당신의 깃발 아래 서겠다고 맹세하는 자들이.",
                "하지만 말만으로는 부족해요. 서약서가 필요합니다. 진짜 충성은 피로 쓰이는 법이니까요.",
            ],
            on_interact: [AdvancePhase("gather_lords")],
            auto_advance: [],
            objective: Some("아버지의 복수를 위해 전쟁을 준비해야 한다. 캣린의 말을 모두 들어라."),
        ),

        // ── 전개 1: 영주 소집 ─────────────────────────────────────────────
        "gather_lords": QuestPhaseDef(
            dialog: [
                "글로버 경, 모르몬트 경, 카스타크 경... 모두 당신을 기다리고 있어요.",
                "폐허 속 어딘가에 서약서가 숨겨져 있을 거예요. 그것을 찾아오세요.",
                "충성 서약서 하나면 충분해요. 나머지는 제가 설득할게요.",
            ],
            on_interact: [],
            auto_advance: [
                AutoAdvance(
                    condition: HasItem("lords_oath"),
                    next_phase: "lords_gathered",
                ),
            ],
            objective: Some("폐허에서 충성 서약서를 찾아라. 북부 영주들이 결집하고 있다."),
        ),

        // ── 전개 2: 집결 완료, 전략 수립 ─────────────────────────────────
        "lords_gathered": QuestPhaseDef(
            dialog: [
                "왔군요. 카스타크 경이 합류했고 글로버 경도 기병 3백을 보내왔어요.",
                "제이미 라니스터의 본대가 남쪽 숲길을 통해 이동 중이에요.",
                "속삭이는 숲... 그곳이 매복 지점이에요. 그 좁은 길목에서 그들을 가둬야 해요.",
                "하지만 조심하세요. 제이미는 킹슬레이어예요. 칼솜씨가 서부 전체에서 으뜸이에요.",
            ],
            on_interact: [AdvancePhase("ambush_prep")],
            auto_advance: [],
            objective: Some("캣린에게 다음 작전을 들어라."),
        ),

        // ── 전개 3: 매복 준비 ─────────────────────────────────────────────
        "ambush_prep": QuestPhaseDef(
            dialog: [
                "기병대는 이미 숲 양쪽에 배치했어요. 정찰병들이 앞서 가고 있고요.",
                "당신이 할 일은 하나예요 — 제이미를 찾아내서 싸움을 끝내는 것.",
                "아이스를 쥐고 앞으로 나아가세요. 두려움이 그들 사이에서 먼저 달릴 거예요.",
            ],
            on_interact: [AdvancePhase("ambush_strike")],
            auto_advance: [],
            objective: Some("속삭이는 숲으로 향하라. 매복 신호를 기다렸다가 전진한다."),
        ),

        // ── 절정 1: 매복 개시 ─────────────────────────────────────────────
        "ambush_strike": QuestPhaseDef(
            dialog: [
                "신호가 울렸다.",
                "숲 양쪽에서 기병대가 쏟아져 나왔고, 라니스터 병사들은 채 대형을 갖추기도 전에 포위됐다.",
                "말발굽 소리, 쇠붙이 부딪히는 소리, 비명. 전장은 순식간에 지옥이 됐다.",
            ],
            on_interact: [
                Log("【전투】 롭은 아이스를 높이 들고 적진 한복판으로 돌격했다."),
                Log("【광역 휘두르기】 거대한 검이 호를 그리자 앞을 막는 병사 셋이 동시에 쓰러졌다."),
                Log("라니스터 병사들이 갈라지며 뒤로 물러났다. 그리고 그 중심에서 황금 갑옷이 모습을 드러냈다."),
                AdvancePhase("duel_jaime"),
            ],
            auto_advance: [],
            objective: Some("적진으로 돌격하라. 제이미 라니스터를 찾아내야 한다."),
        ),

        // ── 절정 2: 제이미와 결투 ─────────────────────────────────────────
        "duel_jaime": QuestPhaseDef(
            dialog: [
                "제이미 라니스터였다. 황금 머리카락, 비웃는 눈빛, 그리고 피 한 방울 묻지 않은 검.",
                "\"스타크. 아버지를 닮았군. 그 눈빛이.\" 그가 검을 뽑으며 말했다.",
                "결투가 시작됐다. 제이미의 검술은 빠르고 정교했다. 하지만 아이스는 그보다 무거웠고, 더 깊은 곳에서 오는 힘이 있었다.",
            ],
            on_interact: [
                Log("【결투】 제이미의 첫 번째 공격 — 왼쪽 어깨를 노리는 빠른 찌르기."),
                Log("롭은 검을 틀어 흘려냈다. 아이스의 무게가 제이미의 팔을 흔들었다."),
                Log("【명예로운 일격】 롭은 제이미의 허점을 찌르는 대신 검 옆면으로 손목을 쳤다. 제이미의 검이 땅에 떨어졌다."),
                Log("제이미가 무릎을 꿇었다. \"...이기는군. 스타크답게.\" 그가 낮게 말했다."),
                GiveItem("jaime_sword"),
                AdvancePhase("jaime_captured"),
            ],
            auto_advance: [],
            objective: Some("제이미 라니스터와 맞서 싸워라. 죽이지 않는다 — 생포해야 한다."),
        ),

        // ── 전환: 생포 후 귀환 ────────────────────────────────────────────
        "jaime_captured": QuestPhaseDef(
            dialog: [
                "제이미를 포박했다는 소식이 전장에 퍼졌다.",
                "라니스터 병사들이 무기를 내려놓기 시작했다. 지휘관을 잃은 군대는 싸울 의지가 없었다.",
                "캣린이 달려왔다. 눈에 눈물이 맺혀 있었지만 목소리는 흔들리지 않았다.",
                "\"당신 아버지가 이 모습을 봤다면... 자랑스러워하셨을 거예요, 롭.\"",
            ],
            on_interact: [AdvancePhase("coronation_prep")],
            auto_advance: [],
            objective: Some("캣린에게 돌아가라. 전투는 끝났다."),
        ),

        // ── 결말: 대관식 ──────────────────────────────────────────────────
        "coronation_prep": QuestPhaseDef(
            dialog: [
                "영주들이 모였다. 글로버, 모르몬트, 카스타크, 아린, 맬리스터, 프레이.",
                "누군가 검을 들어 하늘로 향했다. 그리고 연호가 시작됐다.",
                "\"북부의 왕! 롭 스타크, 북부의 왕!\" 목소리들이 하나로 합쳐졌다.",
                "캣린이 왕관을 내밀었다. \"이것이 당신의 것이에요, 폐하.\"",
            ],
            on_interact: [
                Log("【대관식】 왕관이 머리 위에 올려졌다. 차갑고 무거웠다."),
                Log("롭 스타크는 북부의 왕이 됐다. 그리고 그 순간, 돌아갈 길이 없다는 것을 알았다."),
                Log("아버지의 복수는 이제 시작이다. 킹스랜딩이 기다리고 있다."),
                GiveItem("kings_north_crown"),
                SetFlag(flag: "title", value: "king_in_the_north"),
                AdvancePhase("king_end"),
            ],
            auto_advance: [],
            objective: Some("대관식에 임하라."),
        ),

        "king_end": QuestPhaseDef(
            dialog: [],
            on_interact: [],
            auto_advance: [],
            objective: Some("나는 북부의 왕, 롭 스타크다. 킹스랜딩으로 남하한다."),
        ),
    },

    spawns: [
        QuestSpawn(phase: "gather_lords", item: "lords_oath", zone: Dungeon(1)),
    ],
)
