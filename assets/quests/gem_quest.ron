#![enable(implicit_some)]

QuestDef(
    id: "gem_quest",
    title: "잃어버린 보석",
    giver_npc: "elder",
    initial_phase: "not_started",
    spawn_chance: 0.8,

    phases: {
        "not_started": QuestPhaseDef(
            dialog: [
                "오, 모험가여. 부탁이 있소.",
                "던전 2층에 '영원의 보석'이 숨겨져 있다오.",
                "그것을 찾아 내게 가져다 주겠소?",
            ],
            objective: Some("장로의 부탁을 들어주기로 했다."),
        ),
        "active": QuestPhaseDef(
            dialog: ["아직 보석을 찾지 못했나요? 던전 2층을 살펴보시오."],
            objective: Some("숲을 지나 던전 2층에서 영원의 보석을 찾아라."),
        ),
        "ready": QuestPhaseDef(
            dialog: [
                "오! 보석을 찾아왔군요!",
                "약속대로 '현자의 돌'을 드리겠소.",
            ],
            objective: Some("마을 장로에게 영원의 보석을 가져다 주어라."),
        ),
        "done": QuestPhaseDef(
            dialog: ["덕분에 마을이 평화로워졌소. 감사합니다."],
            objective: Some("퀘스트 완료!"),
        ),
    },

    transitions: [
        // 장로와 첫 대화 → 의뢰 수락
        Transition(from: "not_started", trigger: Interact, to: "active"),
        // 보석을 얻으면 자동으로 반납 준비 단계로
        Transition(from: "active", trigger: Auto, when: HasItem("eternal_gem"), to: "ready"),
        // 장로에게 보석 반납 → 현자의 돌 수령.
        // 보상으로 산속 마을(Named("mountain_village")) 로 가는 portal 이 시작 마을에 열린다.
        //   - 잃어버린 보석은 첫 quest 류 — 완료 시 새 마을이 자연스럽게 해금된다.
        //   - OpenZonePortal 은 임의 ZoneId(Town/Named) 로 가는 portal 을 만든다 (NamedZoneConfig 등록 X).
        //   - placement: Border — 시작 마을 외곽에 배치되어 입구로 자연스럽게 보인다.
        Transition(from: "ready", trigger: Interact,
            actions: [
                RemoveItem("eternal_gem"),
                GiveItem("philosophers_stone"),
                OpenZonePortal(target: Named("mountain_village"), placement: Border),
            ],
            to: "done"),
    ],

    spawns: [
        QuestSpawn(
            phase: "active",
            item: "eternal_gem",
            zone: Named("dungeon_2"),
        ),
    ],
)
