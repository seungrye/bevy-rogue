// ═══════════════════════════════════════════════════════════════════════════
//  봉인의 각성 — Giga 비선형 퀘스트
//
//  NPC: 노인
//
//  ─── 선행 조건 ────────────────────────────────────────────────────────────
//    gem_quest 완료 필수 (첫 대화 이후 자동 활성화)
//    alchemist_quest 완료는 선택 (완료 수준에 따라 결말 품질 결정)
//
//  ─── 수집 아이템 ──────────────────────────────────────────────────────────
//    eternal_gem        (영원의 보석)   — 던전 2층 스폰
//    philosophers_stone (현자의 돌)    — gem_quest 보상으로만 획득 가능
//    dragon_scale       (용비늘)       — 던전 2층 스폰
//    ancient_scroll     (고대 주문서)  — 던전 1층 스폰
//
//  ─── 결말 5가지 ───────────────────────────────────────────────────────────
//    legendary_ending  : 4성물 + gem_quest 완료 + alchemist 전설 완료
//    normal_ending     : 4성물 + alchemist 일반 or 전설 완료
//    incomplete_ending : 4성물, alchemist 미완료 (강행)
//    wisdom_ending     : 영원의 보석 + 현자의 돌 (2성물, gem_quest only 경로)
//    warrior_ending    : 용비늘 + 고대 주문서 (2성물, alchemist 전설 경로)
//
//  ─── 비선형성 ─────────────────────────────────────────────────────────────
//    auto_advance 11단계 우선순위 체계
//    on_interact Branch 중첩 (최대 3단계)
//    gem_quest / alchemist_quest 교차 참조
//    존 위치 기반 힌트 분기
//    3개 보유 시 4가지 힌트 경로
//    대안 경로 2개 (현자/전사) — 4성물 없이도 완료 가능
// ═══════════════════════════════════════════════════════════════════════════

QuestDef(
    id: "world_fracture",
    title: "봉인의 각성",
    giver_npc: "노인",
    initial_phase: "dormant",

    phases: {

        // ── 잠든 상태: gem_quest 완료 전 ───────────────────────────────────────
        "dormant": QuestPhaseDef(
            dialog: [
                "...허허. 젊은이, 아직은 내 이야기를 들을 때가 아닌 것 같군.",
                "마을 장로와 먼저 이야기해보게. 그 일이 끝나면 다시 찾아오게나.",
                "세상에는 장로의 보석보다 훨씬 중요한 것이 있거든...",
            ],
            on_interact: [
                Branch(
                    condition: PhaseIs(quest: "gem_quest", phase: "done"),
                    if_true: [
                        Log("노인: 오! 드디어 장로의 일을 해결했군. 이제 이야기할 수 있겠어."),
                        AdvancePhase("awakened"),
                    ],
                    if_false: [
                        Log("노인: 장로를 먼저 만나보게. 그 일이 시작의 열쇠야."),
                    ],
                ),
            ],
            auto_advance: [
                AutoAdvance(
                    condition: PhaseIs(quest: "gem_quest", phase: "done"),
                    next_phase: "awakened",
                ),
            ],
            objective: Some("마을 장로의 의뢰를 먼저 완수해야 노인과 제대로 이야기할 수 있을 것 같다."),
        ),

        // ── 깨어남: gem_quest 완료 후 첫 만남 ─────────────────────────────────
        "awakened": QuestPhaseDef(
            dialog: [
                "오, 드디어 왔군. 오래 기다렸어.",
                "장로의 보석 심부름으로 던전을 오간 자네야말로 이 일을 맡을 수 있는 사람이야.",
                "이 마을 아래, 세상의 균열이 천천히 열리고 있다네.",
                "수백 년 전 현자들이 네 개의 성물로 봉인해 두었지만 — 그 봉인이 약해지고 있어.",
                "네 개의 성물: 영원의 보석, 현자의 돌, 용비늘, 고대 주문서.",
                "장로에게서 현자의 돌을 받았겠지? 그것이 핵심 열쇠야.",
                "하지만 혼자서는 충분하지 않아. 연금술사와도 이야기해봐야 해.",
            ],
            on_interact: [
                Branch(
                    condition: PhaseIs(quest: "alchemist_quest", phase: "not_started"),
                    if_true: [
                        Log("노인: 연금술사와 아직 이야기하지 않았군. 그도 이 비밀의 일부를 알고 있어."),
                        Log("노인: 그가 연구하는 재료들 — 용비늘과 고대 주문서 — 은 봉인에 꼭 필요한 것들이야."),
                        AdvancePhase("need_alchemist"),
                    ],
                    if_false: [
                        Branch(
                            condition: Or([
                                PhaseIs(quest: "alchemist_quest", phase: "normal_done"),
                                PhaseIs(quest: "alchemist_quest", phase: "legendary_done"),
                            ]),
                            if_true: [
                                Log("노인: 연금술사의 작업도 끝났군! 훌륭해. 이미 많은 준비가 된 셈이야."),
                                AdvancePhase("prologue_done"),
                            ],
                            if_false: [
                                Log("노인: 연금술사와 이미 접촉했군. 좋아. 그의 작업도 도와주면 봉인이 훨씬 강해질 거야."),
                                AdvancePhase("prologue_done"),
                            ],
                        ),
                    ],
                ),
            ],
            auto_advance: [],
            objective: Some("노인에게서 봉인의 비밀을 들었다. 네 개의 성물을 모아야 한다."),
        ),

        // ── 연금술사 접촉 필요 단계 ────────────────────────────────────────────
        "need_alchemist": QuestPhaseDef(
            dialog: [
                "연금술사를 먼저 만나게. 그는 용비늘과 고대 주문서의 위치를 알고 있어.",
                "그 두 재료는 봉인에 필수야 — 단순한 의뢰가 아니라 더 큰 그림의 일부라는 걸 그도 이해할 거야.",
                "연금술사의 작업이 완성되면 다시 내게 오게나.",
            ],
            on_interact: [
                Branch(
                    condition: Not(PhaseIs(quest: "alchemist_quest", phase: "not_started")),
                    if_true: [
                        Log("노인: 연금술사와 이야기를 나눴군. 이제 함께 성물을 모을 수 있어."),
                        AdvancePhase("prologue_done"),
                    ],
                    if_false: [
                        Log("노인: 아직 연금술사를 만나지 않았군. 마을 어딘가에 있을 거야."),
                    ],
                ),
            ],
            auto_advance: [
                AutoAdvance(
                    condition: Not(PhaseIs(quest: "alchemist_quest", phase: "not_started")),
                    next_phase: "prologue_done",
                ),
            ],
            objective: Some("연금술사를 먼저 만나 봉인에 관한 이야기를 들어야 한다."),
        ),

        // ── 서막 완료, 본격 수집 시작 ──────────────────────────────────────────
        "prologue_done": QuestPhaseDef(
            dialog: [
                "좋아. 이제 본론이야.",
                "성물 네 개 모두가 필요해. 하나라도 빠지면 봉인은 불완전해.",
                "영원의 보석 — 던전 2층 깊은 곳.",
                "현자의 돌 — 장로에게 보석을 바쳤으니 이미 갖고 있겠지.",
                "용비늘 — 던전 2층. 연금술사의 의뢰를 따르면 자연스럽게 찾게 될 거야.",
                "고대 주문서 — 던전 1층 어딘가.",
                "그리고 하나 더 — 연금술사의 작업이 '전설적' 수준으로 완성된다면,",
                "봉인의 강도가 몇 배는 강해질 거야. 그것도 고려해봐.",
            ],
            on_interact: [AdvancePhase("gathering_all")],
            auto_advance: [],
            objective: Some("성물 4개를 수집하라: 영원의 보석(던전2), 현자의 돌(장로→교환), 용비늘(던전2), 고대 주문서(던전1)."),
        ),

        // ── 메인 수집 단계 — auto_advance 11단계 우선순위 ────────────────────
        "gathering_all": QuestPhaseDef(
            dialog: [
                "아직 성물이 다 모이지 않았어.",
                "던전을 탐험하고, 연금술사의 의뢰도 챙기면서 재료를 모아봐.",
            ],
            on_interact: [
                Branch(
                    condition: And([
                        HasItem("eternal_gem"),
                        HasItem("philosophers_stone"),
                        HasItem("dragon_scale"),
                        HasItem("ancient_scroll"),
                    ]),
                    if_true: [
                        Log("노인: 네 개가 모두 있군! 이제 의식을 시작할 수 있어."),
                        AdvancePhase("all_gathered"),
                    ],
                    if_false: [
                        Branch(
                            condition: Not(HasItem("philosophers_stone")),
                            if_true: [Log("노인: 현자의 돌이 없군. 장로에게 영원의 보석을 바치면 받을 수 있어.")],
                            if_false: [
                                Branch(
                                    condition: Not(HasItem("eternal_gem")),
                                    if_true: [Log("노인: 영원의 보석이 없군. 던전 2층을 깊이 탐험해야 해.")],
                                    if_false: [Log("노인: 좋아. 보석과 현자의 돌은 있군. 나머지를 던전에서 찾아봐.")],
                                ),
                            ],
                        ),
                    ],
                ),
            ],
            auto_advance: [
                // 1순위: 4성물 + gem_quest 완료 + alchemist 전설 → 전설 준비
                AutoAdvance(
                    condition: And([
                        HasItem("eternal_gem"),
                        HasItem("philosophers_stone"),
                        HasItem("dragon_scale"),
                        HasItem("ancient_scroll"),
                        PhaseIs(quest: "gem_quest", phase: "done"),
                        PhaseIs(quest: "alchemist_quest", phase: "legendary_done"),
                    ]),
                    next_phase: "legendary_ready",
                ),
                // 2순위: 4성물 + alchemist 일반 완료 → 일반 준비
                AutoAdvance(
                    condition: And([
                        HasItem("eternal_gem"),
                        HasItem("philosophers_stone"),
                        HasItem("dragon_scale"),
                        HasItem("ancient_scroll"),
                        PhaseIs(quest: "alchemist_quest", phase: "normal_done"),
                    ]),
                    next_phase: "normal_ready",
                ),
                // 3순위: 4성물 (alchemist 미완료) → 대기 단계
                AutoAdvance(
                    condition: And([
                        HasItem("eternal_gem"),
                        HasItem("philosophers_stone"),
                        HasItem("dragon_scale"),
                        HasItem("ancient_scroll"),
                    ]),
                    next_phase: "all_gathered",
                ),
                // 4순위: 현자의 길 — 보석+현자의돌 + gem_quest 완료 + alchemist 미시작
                AutoAdvance(
                    condition: And([
                        HasItem("eternal_gem"),
                        HasItem("philosophers_stone"),
                        PhaseIs(quest: "gem_quest", phase: "done"),
                        PhaseIs(quest: "alchemist_quest", phase: "not_started"),
                        Not(HasItem("dragon_scale")),
                        Not(HasItem("ancient_scroll")),
                    ]),
                    next_phase: "wisdom_path_entry",
                ),
                // 5순위: 전사의 길 — 비늘+주문서 + alchemist 전설 + 보석 없음
                AutoAdvance(
                    condition: And([
                        HasItem("dragon_scale"),
                        HasItem("ancient_scroll"),
                        PhaseIs(quest: "alchemist_quest", phase: "legendary_done"),
                        Not(HasItem("eternal_gem")),
                        Not(HasItem("philosophers_stone")),
                    ]),
                    next_phase: "warrior_path_entry",
                ),
                // 6순위: 3개 — 현자의돌 없음
                AutoAdvance(
                    condition: And([
                        HasItem("eternal_gem"),
                        HasItem("dragon_scale"),
                        HasItem("ancient_scroll"),
                        Not(HasItem("philosophers_stone")),
                    ]),
                    next_phase: "missing_stone_hint",
                ),
                // 7순위: 3개 — 주문서 없음
                AutoAdvance(
                    condition: And([
                        HasItem("eternal_gem"),
                        HasItem("philosophers_stone"),
                        HasItem("dragon_scale"),
                        Not(HasItem("ancient_scroll")),
                    ]),
                    next_phase: "missing_scroll_hint",
                ),
                // 8순위: 3개 — 보석 없음
                AutoAdvance(
                    condition: And([
                        HasItem("philosophers_stone"),
                        HasItem("dragon_scale"),
                        HasItem("ancient_scroll"),
                        Not(HasItem("eternal_gem")),
                    ]),
                    next_phase: "missing_gem_hint",
                ),
                // 9순위: 3개 — 용비늘 없음
                AutoAdvance(
                    condition: And([
                        HasItem("eternal_gem"),
                        HasItem("philosophers_stone"),
                        HasItem("ancient_scroll"),
                        Not(HasItem("dragon_scale")),
                    ]),
                    next_phase: "missing_scale_hint",
                ),
                // 10순위: 던전 2층 탐험 중이고 용비늘 없음
                AutoAdvance(
                    condition: And([
                        InZone(Dungeon(2)),
                        Not(HasItem("dragon_scale")),
                        HasItem("philosophers_stone"),
                    ]),
                    next_phase: "deep_dungeon_hint",
                ),
                // 11순위: 현자의 돌 없이 보석만 있음
                AutoAdvance(
                    condition: And([
                        HasItem("eternal_gem"),
                        Not(HasItem("philosophers_stone")),
                    ]),
                    next_phase: "get_stone_hint",
                ),
            ],
            objective: Some("성물 4개 수집: 영원의 보석(던전2), 현자의 돌(장로→교환), 용비늘(던전2), 고대 주문서(던전1)."),
        ),

        // ── 힌트 단계들 ────────────────────────────────────────────────────────

        "missing_stone_hint": QuestPhaseDef(
            dialog: [
                "세 개나 모았군! 거의 다 왔어.",
                "현자의 돌만 없구나. 장로에게 영원의 보석을 바치면 받을 수 있지.",
                "이미 영원의 보석을 갖고 있으니 — 장로를 찾아가봐.",
            ],
            on_interact: [],
            auto_advance: [
                AutoAdvance(
                    condition: HasItem("philosophers_stone"),
                    next_phase: "gathering_all",
                ),
            ],
            objective: Some("현자의 돌이 부족하다. 장로에게 영원의 보석을 바쳐 현자의 돌을 받아야 한다."),
        ),

        "missing_scroll_hint": QuestPhaseDef(
            dialog: [
                "세 개나 모았군! 훌륭해.",
                "고대 주문서만 없구나. 던전 1층 어딘가에 있을 거야.",
                "연금술사의 의뢰를 따라가면 자연스럽게 찾게 될 거야.",
            ],
            on_interact: [],
            auto_advance: [
                AutoAdvance(
                    condition: HasItem("ancient_scroll"),
                    next_phase: "gathering_all",
                ),
            ],
            objective: Some("고대 주문서가 부족하다. 던전 1층에서 찾거나 연금술사 의뢰를 진행해야 한다."),
        ),

        "missing_gem_hint": QuestPhaseDef(
            dialog: [
                "세 개나 모았군! 훌륭해.",
                "영원의 보석만 없구나. 던전 2층 깊은 곳에 있을 거야.",
                "그런데... 잠깐. 현자의 돌은 어떻게 얻었지? 장로에게 영원의 보석을 바쳤나?",
                "그렇다면 장로가 받은 보석이 어딘가에 다시 나타날 수도 있어. 던전 2층을 다시 확인해봐.",
            ],
            on_interact: [],
            auto_advance: [
                AutoAdvance(
                    condition: HasItem("eternal_gem"),
                    next_phase: "gathering_all",
                ),
            ],
            objective: Some("영원의 보석이 부족하다. 던전 2층 깊은 곳에서 찾아야 한다."),
        ),

        "missing_scale_hint": QuestPhaseDef(
            dialog: [
                "세 개나 모았군! 거의 다 왔어.",
                "용비늘만 없구나. 던전 2층의 깊은 방에 있을 거야.",
                "위험한 몬스터들이 지키고 있을 테니 조심해. 자네라면 할 수 있을 거야.",
            ],
            on_interact: [],
            auto_advance: [
                AutoAdvance(
                    condition: HasItem("dragon_scale"),
                    next_phase: "gathering_all",
                ),
            ],
            objective: Some("용비늘이 부족하다. 던전 2층 깊은 곳에서 찾아야 한다."),
        ),

        "deep_dungeon_hint": QuestPhaseDef(
            dialog: [
                "던전 2층에 있군. 용비늘이 바로 이 어딘가에 있을 거야.",
                "몬스터들을 물리치면서 방들을 탐험해봐.",
                "마지막 방에 가장 강한 보상이 있는 법이지.",
            ],
            on_interact: [],
            auto_advance: [
                AutoAdvance(
                    condition: HasItem("dragon_scale"),
                    next_phase: "gathering_all",
                ),
                AutoAdvance(
                    condition: Not(InZone(Dungeon(2))),
                    next_phase: "gathering_all",
                ),
            ],
            objective: Some("던전 2층에서 용비늘을 찾아라."),
        ),

        "get_stone_hint": QuestPhaseDef(
            dialog: [
                "영원의 보석은 찾았군. 이제 장로에게 가져가봐.",
                "장로는 보석의 대가로 현자의 돌을 줄 거야.",
                "현자의 돌 없이는 봉인이 완전하지 않아 — 반드시 교환해야 해.",
            ],
            on_interact: [],
            auto_advance: [
                AutoAdvance(
                    condition: HasItem("philosophers_stone"),
                    next_phase: "gathering_all",
                ),
            ],
            objective: Some("장로에게 영원의 보석을 바쳐 현자의 돌을 받아야 한다."),
        ),

        // ── 대안 경로 1: 현자의 길 ─────────────────────────────────────────────
        "wisdom_path_entry": QuestPhaseDef(
            dialog: [
                "흥미롭군. 영원의 보석과 현자의 돌만 갖고 있는 상황이야.",
                "오래된 기록에 따르면 이 두 개만으로도 '정화의 봉인'이 가능하다고 했어.",
                "하지만 효과는 약해. 10년 정도밖에 지속되지 않아.",
                "반면 나머지 두 개를 모아서 완전한 봉인을 할 수도 있어.",
                "연금술사의 의뢰를 따라가면 용비늘과 주문서를 얻을 수 있을 거야.",
                "어떻게 하겠나 — 지금 당장 불완전한 봉인을 하겠나,",
                "아니면 완전한 봉인을 위해 더 노력하겠나?",
            ],
            on_interact: [
                Branch(
                    condition: And([HasItem("dragon_scale"), HasItem("ancient_scroll")]),
                    if_true: [
                        Log("노인: 이미 나머지도 갖고 있군! 완전한 봉인이 가능해!"),
                        AdvancePhase("all_gathered"),
                    ],
                    if_false: [
